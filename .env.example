# ── Mentorix Environment Variables ──
# Copy this file to .env and fill in your values

# App
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://mentorix:mentorix@localhost:5432/mentorix

# Redis
REDIS_URL=redis://localhost:6379/0

# MongoDB (Memory Store)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=mentorix
MEMORY_STORE_BACKEND=mongo
MEMORY_DUAL_WRITE=false

# LLM Provider
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_API_URL=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Embeddings
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
VECTOR_BACKEND=pgvector

# Grounding
GROUNDING_DATA_DIR=class-10-maths
GROUNDING_PREPARE_ON_START=false
GROUNDING_REQUIRE_READY=false
GROUNDING_CHAPTER_COUNT=5

# Auth & Security
GATEWAY_AUTH_ENABLED=false
GATEWAY_API_KEY=
JWT_SECRET=mentorix-dev-secret-change-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-in-production

# Model Governance
ROLE_MODEL_GOVERNANCE_ENABLED=true
MODEL_REGISTRY_FILE=CONFIG/models_registry.json

# Email (for reminders)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Scheduler
SCHEDULER_ENABLED=false
SCHEDULER_TICK_SECONDS=2

# Reading Config
READING_MIN_SECONDS=60
READING_MAX_SECONDS=300
READING_ESTIMATE_WPM=150
